generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  pointName String   @default("points")
  createdAt DateTime @default(now())

  staff     Staff[]
  youth     Youth[]
  behaviors Behavior[]
  prizes    Prize[]
  behaviorRequests BehaviorRequest[]
}

model Staff {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String   @unique
  passwordHash   String
  role           Role     @default(LEADER)
  organizationId Int
  createdAt      DateTime @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  pointTransactions PointTransaction[]
  redemptions       Redemption[]
  behaviorRequests BehaviorRequest[]
}

model Youth {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  dob            DateTime
  grade          String?
  qrCode         String   @unique @default(uuid())
  points         Int      @default(0)
  organizationId Int
  createdAt      DateTime @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  pointTransactions PointTransaction[]
  redemptions       Redemption[]
}

model Behavior {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  minPoints      Int
  maxPoints      Int
  organizationId Int
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  pointTransactions PointTransaction[]
}

model PointTransaction {
  id         Int      @id @default(autoincrement())
  youthId    Int
  staffId    Int
  behaviorId Int
  points     Int
  note       String?
  createdAt  DateTime @default(now())
  behaviorRequestId Int?
  behaviorRequest   BehaviorRequest? @relation(fields: [behaviorRequestId], references: [id])

  youth    Youth    @relation(fields: [youthId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
  behavior Behavior @relation(fields: [behaviorId], references: [id])
}

model Prize {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  pointCost      Int
  quantity       Int      @default(1)
  requiresAdmin  Boolean  @default(false)
  organizationId Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  redemptions  Redemption[]
}

model Redemption {
  id        Int              @id @default(autoincrement())
  youthId   Int
  prizeId   Int
  staffId   Int?
  status    RedemptionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  youth Youth  @relation(fields: [youthId], references: [id])
  prize Prize  @relation(fields: [prizeId], references: [id])
  staff Staff? @relation(fields: [staffId], references: [id])
}

model BehaviorRequest {
  id             Int                   @id @default(autoincrement())
  name           String
  description    String?
  minPoints      Int
  maxPoints      Int
  organizationId Int
  requestedById  Int
  status         BehaviorRequestStatus @default(PENDING)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id])
  requestedBy   Staff              @relation(fields: [requestedById], references: [id])
  pointTransactions PointTransaction[]
}

enum Role {
  ADMIN
  LEADER
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BehaviorRequestStatus {
  PENDING
  APPROVED
  REJECTED
}